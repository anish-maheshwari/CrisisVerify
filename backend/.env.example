# ── LLM (Google Gemini) ───────────────────────
# Get key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# ── Search / Evidence (Serper.dev) ───────────
# Get key at: https://serper.dev
# If blank, the app will use realistic mock evidence (good for demos)
SERPER_API_KEY=

# ── Rate Limiting ─────────────────────────────
# Requests per minute per IP
RATE_LIMIT_PER_MINUTE=10
